# Copy to fastlane/.env (gitignored) and fill in. Fastlane loads .env from ./fastlane when present.
# Avoid US-ASCII errors when uploading metadata (smart quotes in txt files):
# LC_ALL=en_US.UTF-8
# LANG=en_US.UTF-8
#
# Apple ID is also set in Appfile; override with FASTLANE_USER if needed.
#
# IPA uploads use Xcode altool — with 2FA you MUST set an app-specific password (appleid.apple.com):
# FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
#
# Option A — App Store Connect API (recommended for CI and TestFlight)
# APP_STORE_CONNECT_KEY_ID=
# APP_STORE_CONNECT_ISSUER_ID=
# Optional if key is at ~/.private_keys/AuthKey_<KEY_ID>.p8
# APP_STORE_CONNECT_KEY_PATH=
#
# Option B — Apple ID (also in fastlane/Appfile) + app-specific password for non-interactive upload
# FASTLANE_USER=
# FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD=
# Interactive Terminal: you can omit these; Fastlane will prompt and store in Keychain.
#
# Optional: IPA from a custom path (default: external drive output or build/ipa/)
# IPA_PATH=
#
# TestFlight external tester import (fastlane import_external_testers)
# Exact group name from App Store Connect → TestFlight → Groups (default used if unset: External Testing)
# TESTFLIGHT_EXTERNAL_GROUP=
