{
  "expo": {
    "name": "Adelynn's Quest",
    "slug": "mobile-game",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile-game",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a1f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.adelynn.adventurequest",
      "buildNumber": "1",
      "appleTeamId": "4SQJ3AH62S"
    },
    "android": {},
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "adelynn-aq-4sqj3-001"
      }
    }
  }
}
